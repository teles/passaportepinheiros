---
import { ArrowRight, CircleCheck, Heart, Sparkles } from '@lucide/astro';
import {
  categoryLabel,
  compactDescription,
  experiencePath,
  searchPayload,
  type Experience,
} from '../lib/experiences';

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
const { data } = experience;
const href = experiencePath(experience);
const description = compactDescription(data.description);
const experienceId = `${data.category}:${data.slug}`;
---

<article
  class="experience-card group relative flex min-h-[430px] flex-col overflow-hidden rounded-lg border border-border/70 bg-surface transition duration-200 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-[0_18px_44px_rgba(0,110,199,0.12)]"
  data-experience-card
  data-category={data.category}
  data-slug={data.slug}
  data-experience-id={experienceId}
  data-search={searchPayload(experience)}
>
  <div class="relative aspect-[4/3] overflow-hidden bg-surface-muted">
    <a href={href} aria-label={`Ver ${data.title}`}>
      <img
        src={data.images.experience}
        alt={`Foto de ${data.title}`}
        class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        loading="lazy"
      />
    </a>
    <button
      type="button"
      class="visited-button focus-ring absolute left-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-border bg-surface/95 text-primary shadow-sm transition"
      data-visited-button
      data-visited-id={experienceId}
      data-no-modal
      title="Marcar como visitado"
      aria-label={`Marcar ${data.title} como visitado`}
      aria-pressed="false"
    >
      <CircleCheck class="h-5 w-5" aria-hidden="true" />
    </button>
    <button
      type="button"
      class="favorite-button focus-ring absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-border bg-surface/95 text-primary shadow-sm transition"
      data-favorite-button
      data-favorite-id={experienceId}
      data-no-modal
      aria-label={`Favoritar ${data.title}`}
      aria-pressed="false"
    >
      <Heart class="h-5 w-5" aria-hidden="true" />
    </button>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-4 flex min-h-[5.25rem] items-start gap-3">
      <img
        src={data.images.logo}
        alt={`Logo de ${data.title}`}
        class="h-12 w-12 shrink-0 rounded-full border border-border/60 bg-white object-contain p-1"
        loading="lazy"
      />
      <div class="min-w-0">
        <p class="brand-heading text-xs font-bold text-primary">
          {categoryLabel(data.category)}
        </p>
        <h2 class="brand-heading mt-1 line-clamp-2 min-h-12 text-2xl font-bold leading-none text-ink">
          <a href={href} class="hover:underline">{data.title}</a>
        </h2>
      </div>
    </div>

    <p class="line-clamp-3 min-h-[4.875rem] text-[15px] leading-relaxed text-muted">{description}</p>

    <div class="mt-5 border-t border-border/60 pt-4">
      <div class="flex items-start gap-3">
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-soft text-primary">
          <Sparkles class="h-5 w-5" aria-hidden="true" />
        </span>
        <p class="brand-heading text-sm font-bold leading-snug text-primary">
          Benefício Passaporte
        </p>
      </div>
    </div>

    <div class="mt-auto flex min-w-0 items-center justify-between gap-4 pt-5">
      <a
        href={data.instagramUrl}
        target="_blank"
        rel="noreferrer"
        data-no-modal
        class="inline-flex min-w-0 items-center gap-2 text-sm font-semibold text-muted hover:text-primary"
      >
        <svg
          class="h-4 w-4 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
        </svg>
        <span class="truncate">@{data.instagram}</span>
      </a>
      <a
        href={href}
        data-no-modal
        class="inline-flex shrink-0 items-center gap-1 font-display text-sm font-bold uppercase tracking-wide text-primary hover:text-primary-strong"
      >
        Ver
        <ArrowRight class="h-4 w-4" aria-hidden="true" />
      </a>
    </div>
  </div>
</article>
