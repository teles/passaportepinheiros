---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'faq'>[];
}

const { items } = Astro.props;

const sorted = [...items].sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (item) => {
    const { Content } = await render(item);
    return { ...item, Content };
  }),
);
---

<section class="container-shell py-12 md:py-16">
  <h2 class="font-display text-3xl font-extrabold text-primary md:text-4xl">
    <span class="text-primary">Dúvidas</span> Frequentes
  </h2>
  <p class="mt-3 text-muted">Tudo o que você precisa saber para aproveitar o melhor do bairro.</p>

  <div class="mt-10 space-y-3">
    {
      rendered.map((item, index) => (
        <div
          class="accordion-item overflow-hidden rounded-lg border border-border/70 bg-surface shadow-sm"
          id={`faq-item-${index}`}
        >
          <button
            class="accordion-trigger flex w-full items-center justify-between gap-4 bg-surface px-6 py-5 text-left text-ink transition-colors hover:bg-surface-muted hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary aria-expanded:bg-primary aria-expanded:text-white"
            aria-expanded="false"
            aria-controls={`faq-panel-${index}`}
          >
            <span class="font-display text-sm font-bold uppercase tracking-wider">
              {item.data.question}
            </span>
            <svg
              class="accordion-icon h-5 w-5 shrink-0 transition-transform duration-300"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id={`faq-panel-${index}`}
            class="accordion-panel grid grid-rows-[0fr] bg-surface transition-[grid-template-rows] duration-300"
            role="region"
          >
            <div class="overflow-hidden">
              <div class="px-6 py-5 font-body leading-relaxed text-muted">
                <item.Content />
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.accordion-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll<HTMLButtonElement>('.accordion-trigger').forEach((t) => {
        t.setAttribute('aria-expanded', 'false');
        const panel = document.getElementById(t.getAttribute('aria-controls')!);
        panel?.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
      });

      // Open clicked if it was closed
      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        const panel = document.getElementById(trigger.getAttribute('aria-controls')!);
        panel?.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
      }
    });
  });
</script>
