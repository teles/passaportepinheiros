---
import { ChevronDown, Menu, X } from '@lucide/astro';
import { withBase, withoutBase } from '../lib/urls';

const pathname = withoutBase(Astro.url.pathname);

const isExperienciasActive =
  pathname.startsWith('/restaurantes') ||
  pathname.startsWith('/servicos') ||
  pathname.startsWith('/produtos');

const topLinks = [
  { href: withBase('/'), label: 'Explorar', active: pathname === '/' || pathname.startsWith('/experiencias') },
  { href: withBase('/sobre/'), label: 'Sobre', active: pathname.startsWith('/sobre') },
  { href: withBase('/como-funciona/'), label: 'Como funciona', active: pathname.startsWith('/como-funciona') },
];

const subLinks = [
  { href: withBase('/restaurantes/'), label: 'Restaurantes', active: pathname.startsWith('/restaurantes') },
  { href: withBase('/servicos/'), label: 'Serviços', active: pathname.startsWith('/servicos') },
  { href: withBase('/produtos/'), label: 'Produtos', active: pathname.startsWith('/produtos') },
];

const mobileLinks = [
  { href: withBase('/'), label: 'Explorar', active: pathname === '/' || pathname.startsWith('/experiencias') },
  ...subLinks,
  { href: withBase('/sobre/'), label: 'Sobre', active: pathname.startsWith('/sobre') },
  { href: withBase('/como-funciona/'), label: 'Como funciona', active: pathname.startsWith('/como-funciona') },
];
---

<header class="sticky top-0 z-40 border-b border-border/70 bg-white/95 backdrop-blur dark:bg-[#162130]/95">
  <div class="container-shell flex h-20 items-center justify-between gap-6">
    <a href={withBase('/')} class="flex items-center" aria-label="Passaporte Pinheiros">
      <img
        src={withBase('/brand/logo-passaporte-pinheiros.svg')}
        alt="Passaporte Pinheiros"
        class="h-10 w-auto dark:hidden md:h-12"
      />
      <img
        src={withBase('/brand/logo-passaporte-pinheiros-white.svg')}
        alt="Passaporte Pinheiros"
        class="hidden h-10 w-auto dark:block md:h-12"
      />
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Navegação principal">
      <a
        href={topLinks[0].href}
        class:list={[
          'font-body text-[14px] font-semibold uppercase tracking-wide transition-colors hover:text-primary',
          topLinks[0].active ? 'mt-2 border-b-2 border-primary pb-1 text-primary' : 'text-muted',
        ]}
        aria-current={topLinks[0].active ? 'page' : undefined}
      >
        {topLinks[0].label}
      </a>

      <!-- Experiências dropdown -->
      <div class="relative" data-dropdown>
        <button
          type="button"
          class:list={[
            'inline-flex cursor-pointer items-center gap-1 bg-transparent p-0 text-[14px] font-semibold uppercase tracking-wide transition-colors hover:text-primary',
            isExperienciasActive ? 'mt-2 border-b-2 border-primary pb-1 text-primary' : 'text-muted',
          ]}
          aria-haspopup="true"
          aria-expanded="false"
          data-dropdown-trigger
        >
          Experiências
          <ChevronDown class="h-4 w-4 transition-transform duration-200" data-dropdown-chevron aria-hidden="true" />
        </button>

        <div
          class="absolute left-1/2 top-full z-50 hidden w-44 -translate-x-1/2 translate-y-2 rounded-lg border border-border/70 bg-white py-1 shadow-lg dark:bg-[#162130]"
          data-dropdown-menu
          role="menu"
        >
          {subLinks.map((link) => (
            <a
              href={link.href}
              role="menuitem"
              class:list={[
                'block px-4 py-2.5 font-display text-sm font-bold uppercase tracking-wide transition-colors hover:bg-surface-soft hover:text-primary',
                link.active ? 'text-primary' : 'text-muted',
              ]}
              aria-current={link.active ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <a
        href={topLinks[1].href}
        class:list={[
          'font-body text-[14px] font-semibold uppercase tracking-wide transition-colors hover:text-primary',
          topLinks[1].active ? 'mt-2 border-b-2 border-primary pb-1 text-primary' : 'text-muted',
        ]}
        aria-current={topLinks[1].active ? 'page' : undefined}
      >
        {topLinks[1].label}
      </a>

      <a
        href={topLinks[2].href}
        class:list={[
          'font-body text-[14px] font-semibold uppercase tracking-wide transition-colors hover:text-primary',
          topLinks[2].active ? 'mt-2 border-b-2 border-primary pb-1 text-primary' : 'text-muted',
        ]}
        aria-current={topLinks[2].active ? 'page' : undefined}
      >
        {topLinks[2].label}
      </a>
    </nav>

    <a
      class="primary-cta brand-pill hidden px-5 py-3 font-display text-sm font-bold uppercase tracking-wide transition md:inline-flex"
      href="https://passaporte-pinheiros.pay.yampi.com.br/checkout?skipToCheckout=1&tokenReference=B50R2ZHEK8"
    >
      Garanta seu Passaporte
    </a>

    <button
      class="focus-ring inline-flex h-11 w-11 items-center justify-center rounded border border-border text-primary md:hidden"
      type="button"
      data-mobile-menu-button
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Abrir menu"
    >
      <Menu class="menu-open h-5 w-5" aria-hidden="true" />
      <X class="menu-close hidden h-5 w-5" aria-hidden="true" />
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="container-shell hidden border-t border-border/70 py-3 md:hidden"
    data-mobile-menu
    aria-label="Navegação mobile"
  >
    <div class="grid gap-1">
      {
        mobileLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded px-3 py-3 font-display text-sm font-bold uppercase tracking-wide',
              link.active ? 'bg-primary text-white' : 'text-primary hover:bg-surface-muted',
            ]}
            aria-current={link.active ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const menuButton = document.querySelector('[data-mobile-menu-button]');
  const menu = document.querySelector('[data-mobile-menu]');
  const hasExperienceFilters = () => Boolean(document.querySelector('[data-filter-overlay]'));
  const setMenuIconOpen = (open: boolean) => {
    menuButton?.querySelector('.menu-open')?.classList.toggle('hidden', open);
    menuButton?.querySelector('.menu-close')?.classList.toggle('hidden', !open);
  };

  menuButton?.addEventListener('click', () => {
    if (hasExperienceFilters()) {
      menu?.classList.add('hidden');
      menuButton.setAttribute('aria-controls', 'experience-filters');
      menuButton.setAttribute('aria-expanded', 'true');
      menuButton.setAttribute('aria-label', 'Abrir filtros');
      setMenuIconOpen(true);
      window.dispatchEvent(new CustomEvent('experience-filters:open'));
      return;
    }

    const expanded = menuButton.getAttribute('aria-expanded') === 'true';
    menuButton.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden', expanded);
    setMenuIconOpen(!expanded);
  });

  window.addEventListener('experience-filters:closed', () => {
    menuButton?.setAttribute('aria-expanded', 'false');
    setMenuIconOpen(false);
  });

  // Desktop dropdown
  document.querySelectorAll('[data-dropdown]').forEach((dropdown) => {
    const trigger = dropdown.querySelector('[data-dropdown-trigger]');
    const dropMenu = dropdown.querySelector('[data-dropdown-menu]');
    const chevron = dropdown.querySelector('[data-dropdown-chevron]');

    const open = () => {
      dropMenu?.classList.remove('hidden');
      trigger?.setAttribute('aria-expanded', 'true');
      (chevron as HTMLElement | null)?.style.setProperty('transform', 'rotate(180deg)');
    };
    const close = () => {
      dropMenu?.classList.add('hidden');
      trigger?.setAttribute('aria-expanded', 'false');
      (chevron as HTMLElement | null)?.style.setProperty('transform', '');
    };

    trigger?.addEventListener('click', () => {
      dropMenu?.classList.contains('hidden') ? open() : close();
    });

    // Close when focus leaves the dropdown
    dropdown.addEventListener('focusout', (e) => {
      if (!dropdown.contains((e as FocusEvent).relatedTarget as Node)) close();
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) close();
    });
  });

</script>
