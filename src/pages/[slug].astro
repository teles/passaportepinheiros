---
import { getCollection } from 'astro:content';
import { ArrowLeft, AtSign, ExternalLink, Globe, MapPin, MessageCircle, Phone, Sparkles } from '@lucide/astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  categoryLabel,
  compactDescription,
  descriptionParagraphs,
  sortExperiences,
  type Experience,
} from '../lib/experiences';
import { withBase } from '../lib/urls';

export async function getStaticPaths() {
  const experiences = await getCollection('experiencias');

  return experiences.map((experience) => ({
    params: {
      slug: experience.data.slug,
    },
    props: { experience },
  }));
}

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
const { data } = experience;
const allExperiences = sortExperiences(await getCollection('experiencias'));
const related = allExperiences
  .filter((item) => item.data.category === data.category && item.data.slug !== data.slug)
  .slice(0, 3);
const fallbackDescription = 'Informações da experiência em atualização.';
const description = data.description ?? fallbackDescription;
const benefitDescription = data.description
  ? compactDescription(data.description, 180)
  : 'Benefício Passaporte em atualização.';
const paragraphs = descriptionParagraphs(description);
type Endereco = (typeof data.enderecos)[number];
type Telefone = Endereco['telefones'][number];

const formatEndereco = (endereco: Endereco) =>
  `${endereco.logradouro}, ${endereco.numero}`;

const primeiroEndereco = data.enderecos[0];
const localizacaoResumo = primeiroEndereco
  ? formatEndereco(primeiroEndereco)
  : 'Pinheiros, São Paulo';

const telefoneMeta = (telefone: Telefone) => {
  const isLinkable = /^\d{10,11}$/.test(telefone.numero);

  if (!isLinkable) {
    return {
      href: '',
      label: telefone.tipo === 'whatsapp' ? 'WhatsApp' : 'Telefone',
      external: false,
    };
  }

  return telefone.tipo === 'whatsapp'
    ? {
        href: `https://wa.me/55${telefone.numero}`,
        label: 'WhatsApp',
        external: true,
      }
    : {
        href: `tel:+55${telefone.numero}`,
        label: 'Telefone',
        external: false,
      };
};
---

<BaseLayout title={data.title} description={compactDescription(description, 156)}>
  <article>
    <section class="relative overflow-hidden bg-primary text-white">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_20%,rgba(255,255,255,0.22),transparent_30%),linear-gradient(135deg,var(--color-primary-strong),var(--color-primary))]"></div>
      {data.images?.experience && (
        <img
          src={withBase(data.images.experience)}
          alt={`Foto de ${data.title}`}
          class="absolute inset-0 h-full w-full object-cover opacity-45"
          loading="eager"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/70 to-primary/25"></div>

      <div class="container-shell relative min-h-[420px] py-8 md:min-h-[500px] md:py-12">
        <a
          href={withBase('/')}
          class="detail-back-button focus-ring inline-flex items-center gap-2 rounded px-4 py-2 text-sm font-semibold transition"
        >
          <ArrowLeft class="h-4 w-4" aria-hidden="true" />
          Voltar
        </a>

        <div class="absolute bottom-8 left-0 right-0 px-4 md:bottom-12 md:px-0">
          <div class="container-shell px-0">
            <div class="mb-5 flex flex-wrap items-center gap-3">
              <span class="rounded bg-white px-3 py-1 font-display text-xs font-bold uppercase tracking-wide text-primary">
                {categoryLabel(data.category)}
              </span>
              {data.instagram && (
                <span class="inline-flex items-center gap-2 rounded bg-white/15 px-3 py-1 text-sm font-semibold backdrop-blur">
                  <AtSign class="h-4 w-4" aria-hidden="true" />
                  @{data.instagram}
                </span>
              )}
              {data.categoria_fsq && (
                <span class="rounded bg-white/15 px-3 py-1 text-sm font-semibold backdrop-blur">
                  {data.categoria_fsq}
                </span>
              )}
            </div>

            <div class="flex max-w-4xl items-end gap-5">
              {data.images?.logo ? (
                <img
                  src={withBase(data.images.logo)}
                  alt={`Logo de ${data.title}`}
                  class="hidden h-20 w-20 rounded-lg border border-white/70 bg-white object-contain p-2 md:block"
                />
              ) : (
                <span class="hidden h-20 w-20 shrink-0 items-center justify-center rounded-lg border border-white/70 bg-white/95 text-primary md:inline-flex">
                  <Sparkles class="h-8 w-8" aria-hidden="true" />
                </span>
              )}
              <div>
                <h1 class="font-display text-4xl font-extrabold leading-[1.05] md:text-6xl">{data.title}</h1>
                <p class="mt-4 inline-flex items-center gap-2 text-base font-semibold text-white/90">
                  <MapPin class="h-5 w-5" aria-hidden="true" />
                  {localizacaoResumo}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="container-shell grid gap-8 py-10 md:grid-cols-[1fr_360px] md:py-14">
      <div>
        <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">A experiência</p>
        <div class="mt-4 grid max-w-3xl gap-4 text-lg leading-relaxed text-muted">
          {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>

      <aside class="rounded-lg border border-border/70 bg-surface p-6 md:self-start">
        <div class="flex items-start gap-3">
          <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded bg-primary-soft text-primary">
            <Sparkles class="h-5 w-5" aria-hidden="true" />
          </span>
          <div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">Benefício Passaporte</p>
            <p class="mt-2 text-sm leading-relaxed text-muted">{benefitDescription}</p>
          </div>
        </div>

        <div class="mt-6 grid gap-3 border-t border-border/70 pt-5">
          {data.instagramUrl && (
            <a
              href={data.instagramUrl}
              target="_blank"
              rel="noreferrer"
              class="focus-ring inline-flex items-center justify-center gap-2 rounded border border-primary px-4 py-3 font-display text-sm font-bold uppercase tracking-wide text-primary transition hover:bg-primary hover:text-white"
            >
              <AtSign class="h-4 w-4" aria-hidden="true" />
              Ver no Instagram
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </a>
          )}
          {data.website && (
            <a
              href={data.website}
              target="_blank"
              rel="noreferrer noopener"
              class="focus-ring inline-flex items-center justify-center gap-2 rounded border border-border px-4 py-3 font-display text-sm font-bold uppercase tracking-wide text-muted transition hover:border-primary hover:text-primary"
            >
              <Globe class="h-4 w-4" aria-hidden="true" />
              Site oficial
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </a>
          )}
        </div>

        {
          data.enderecos.length > 0 && (
            <div class="mt-6 border-t border-border/70 pt-5">
              <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">
                Endereços e contato
              </p>

              <div class="mt-4 grid gap-4">
                {data.enderecos.map((endereco) => (
                  <div class="rounded border border-border/70 bg-surface-soft/60 p-4">
                    <p class="flex items-start gap-2 text-sm font-semibold leading-relaxed text-ink">
                      <MapPin class="mt-0.5 h-4 w-4 shrink-0 text-primary" aria-hidden="true" />
                      <span>{formatEndereco(endereco)}</span>
                    </p>
                    {endereco.complemento && (
                      <p class="mt-1 pl-6 text-sm leading-relaxed text-muted">
                        {endereco.complemento}
                      </p>
                    )}

                    {endereco.telefones.length > 0 && (
                      <div class="mt-3 flex flex-wrap gap-2">
                        {endereco.telefones.map((telefone) => {
                          const meta = telefoneMeta(telefone);
                          const Icon = telefone.tipo === 'whatsapp' ? MessageCircle : Phone;
                          const content = (
                            <>
                              <Icon class="h-4 w-4" aria-hidden="true" />
                              <span>{meta.label}: {telefone.formatado}</span>
                            </>
                          );

                          return meta.href ? (
                            <a
                              href={meta.href}
                              target={meta.external ? '_blank' : undefined}
                              rel={meta.external ? 'noreferrer' : undefined}
                              class="focus-ring inline-flex items-center gap-2 rounded-full border border-border bg-white px-3 py-2 text-xs font-semibold text-muted transition hover:border-primary hover:text-primary"
                            >
                              {content}
                            </a>
                          ) : (
                            <span class="inline-flex items-center gap-2 rounded-full border border-border bg-white px-3 py-2 text-xs font-semibold text-muted">
                              {content}
                            </span>
                          );
                        })}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </section>
  </article>

  {
    related.length > 0 && (
      <section class="container-shell pb-14">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">Também nessa categoria</p>
            <h2 class="mt-2 font-display text-3xl font-extrabold text-primary">Outras experiências</h2>
          </div>
          <a
            href={withBase(`/${data.category}/`)}
            class="hidden font-display text-sm font-bold uppercase tracking-wide text-primary hover:underline md:inline"
          >
            Ver {categoryLabel(data.category)}
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {related.map((item) => (
            <ExperienceCard experience={item} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
